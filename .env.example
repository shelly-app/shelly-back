NODE_ENV=development
DEBUG=true
PORT=3000
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=shelly
DB_SSL=true
SEED_ADMIN_EMAILS=name@gmail.com,other@gmail.com
# Comma-separated list of allowed browser origins. Leave empty to reflect the
# request origin (convenient for local development).
CORS_ORIGINS=http://localhost:5173
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# S3 image uploads (profile pictures + pet photos). Credentials come from the
# default AWS chain (EC2 IAM role in prod; `aws configure` / AWS_* env locally).
# Uploads are stored under the "media/" key prefix (media/pets/*, media/avatars/*)
# so a single CloudFront "/media/*" behavior can front the private uploads bucket.
S3_UPLOAD_BUCKET=
S3_REGION=us-east-2
ASSET_PUBLIC_BASE_URL=https://cdn.your-domain.com

# Contact-form email delivery through standard SMTP. Gmail is a free option:
# use smtp.gmail.com, port 587, secure=false, and a Google app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
CONTACT_RECIPIENT_EMAIL=support.shellyapp@gmail.com
# Public frontend origin used to build member invitation links.
APP_PUBLIC_URL=http://localhost:5173